{
  "manifest_version": 3,
  "name": "Worklish — Learn from YouTube",
  "version": "0.2.0",
  "key": "",
  "description": "Analyze the YouTube video you're watching for work insights and advanced English expressions.",
  "permissions": ["sidePanel", "tabs", "storage", "unlimitedStorage", "nativeMessaging"],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Open Worklish" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"]
    }
  ]
}
